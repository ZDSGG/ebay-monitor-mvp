APP_NAME=eBay Monitor MVP
APP_ENV=development
DEBUG=true
API_PREFIX=/api
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ebay_monitor
TIMEZONE=UTC
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_API_BASE_URL=https://api.ebay.com
EBAY_AUTH_BASE_URL=https://api.ebay.com
EBAY_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope
EBAY_REQUEST_TIMEOUT_SECONDS=10
EBAY_MAX_RETRIES=3
SCHEDULER_DAILY_HOUR_UTC=9
SCHEDULER_DAILY_MINUTE_UTC=0
ENABLE_SCHEDULER=true
CRON_SECRET=change-this-in-production
